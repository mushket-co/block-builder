{
  "name": "@mushket-co/block-builder",
  "version": "1.5.3",
  "description": "Блочный конструктор для no-code разработки (Beta)",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.esm.js",
      "require": "./dist/core.js"
    },
    "./vue": {
      "types": "./src/vue.ts",
      "import": "./src/vue.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts"
    },
    "./index.esm.css": {
      "import": "./dist/index.esm.css",
      "require": "./dist/index.esm.css"
    },
    "./index.css": {
      "import": "./dist/index.esm.css",
      "require": "./dist/index.esm.css"
    },
    "./BlockBuilderFactory": {
      "types": "./src/BlockBuilderFactory.ts",
      "import": "./src/BlockBuilderFactory.ts"
    }
  },
  "workspaces": [
    "examples/vue3",
    "examples/vue3-core-api",
    "examples/nuxt3",
    "examples/nuxt4",
    "examples/react",
    "examples/next",
    "examples/pure-js-vite",
    "examples/api-usage",
    "examples/pure-js-cdn"
  ],
  "files": [
    "dist",
    "src/vue.ts",
    "src/react.ts",
    "src/react/**/*.ts",
    "src/react/**/*.tsx",
    "src/BlockBuilderFactory.ts",
    "src/BlockBuilderFacade.ts",
    "src/vue/**/*.vue",
    "src/vue/**/*.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.vue",
    "src/pure-js/**/*.ts",
    "src/core/**/*.ts",
    "src/infrastructure/**/*.ts",
    "src/utils/**/*.ts",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/shared/styles/**",
    "!**/__tests__/**",
    "!**/*.test.ts",
    "!**/*.spec.ts"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.cjs",
    "dev:build": "rollup -c rollup.dev.cjs -w",
    "dev:server": "node dev-server.js",
    "dev": "concurrently -k -n BUILD,SERVER -c blue,green \"npm:dev:build\" \"npm:dev:server\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:unit": "jest --testPathPattern=\".*\\.test\\.ts$\"",
    "test:integration": "jest --testPathPattern=\".*\\.integration\\.test\\.ts$\"",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:component": "vitest run",
    "test:component:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e:preview:vue3": "npm run build && npm run build --workspace=examples/vue3 && npm run preview --workspace=examples/vue3",
    "e2e:preview:pure-js": "npm run build && npm run build --workspace=examples/pure-js-vite && npm run preview --workspace=examples/pure-js-vite",
    "e2e:preview:react": "npm run build && npm run build --workspace=examples/react && npm run preview --workspace=examples/react",
    "e2e:previews": "node scripts/start-e2e-previews.mjs",
    "test:ci:full": "npm run test:ci && npm run test:component && npm run test:e2e",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,css}\"",
    "type-check": "tsc --noEmit",
    "start": "node dev-server.js",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "pretest": "npm run type-check",
    "prepublishOnly": "npm run build && npm run type-check",
    "example:vue3": "npm run dev --workspace=examples/vue3",
    "example:pure-js": "npm run dev --workspace=examples/pure-js-vite",
    "example:api-usage": "npm run dev --workspace=examples/api-usage",
    "example:cdn": "npm run dev --workspace=examples/pure-js-cdn",
    "example:vue3-core-api": "npm run dev --workspace=examples/vue3-core-api",
    "example:nuxt3": "npm run dev --workspace=examples/nuxt3",
    "example:nuxt4": "npm run dev --workspace=examples/nuxt4",
    "example:react": "npm run dev --workspace=examples/react",
    "example:next": "npm run dev --workspace=examples/next",
    "examples:install": "npm install"
  },
  "keywords": [
    "block-builder",
    "no-code",
    "constructor",
    "vue3",
    "typescript",
    "clean-architecture",
    "block-editor",
    "page-builder",
    "content-management",
    "form-builder",
    "ui-builder",
    "component-library"
  ],
  "author": "Mushket & Co",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mushket-co/block-builder.git"
  },
  "homepage": "https://github.com/mushket-co/block-builder#readme",
  "bugs": {
    "url": "https://github.com/mushket-co/block-builder/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.8",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.0.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unicorn": "^50.0.1",
    "eslint-plugin-vue": "^9.19.2",
    "express": "^4.18.2",
    "happy-dom": "^17.4.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.2.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.6.1",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.83.4",
    "ts-jest": "^29.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.3.2",
    "vitest": "^3.1.1",
    "vue": "^3.5.22",
    "vue-eslint-parser": "^9.4.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
